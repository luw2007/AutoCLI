_SNAPSHOT_BASE = os.path.join(TRAE_DIR_DEFAULT, "ModularData", "ai-agent", "snapshot")


def _find_snapshot_repo(session_id: str) -> Optional[str]:
    """查找 session 对应的 snapshot v2 git 仓库路径"""
    base = os.environ.get("TRAE_SNAPSHOT_DIR", _SNAPSHOT_BASE)
    # 精确匹配
    v2 = os.path.join(base, session_id, "v2")
    if os.path.isdir(os.path.join(v2, ".git")):
        return v2
    # 前缀匹配
    if os.path.isdir(base):
        for d in os.listdir(base):
            if d.startswith(session_id):
                v2 = os.path.join(base, d, "v2")
                if os.path.isdir(os.path.join(v2, ".git")):
                    return v2
    return None


def _git_log_events(repo_path: str) -> List[Dict]:
    """从 snapshot git 提取 commit 事件列表（所有分支）"""
    r = subprocess.run(
        ["git", "log", "--all", "--format=%H\t%aI\t%s", "--reverse"],
        cwd=repo_path, capture_output=True, text=True
    )
    if r.returncode != 0:
        return []
    events = []
    for line in r.stdout.strip().splitlines():
        parts = line.split("\t", 2)
        if len(parts) < 3:
            continue
        sha, ts, msg = parts
        evt = {"source": "snapshot", "ts": ts, "sha": sha[:12], "message": msg}
        # 解析 commit message 类型
        if msg.startswith("toolcall-"):
            # toolcall-<turn_id>-<call_id>
            segs = msg.split("-", 2)
            if len(segs) >= 3:
                evt["type"] = "toolcall"
                evt["turn_id"] = segs[1]
                evt["call_id"] = segs[2]
        elif msg.startswith("user-"):
            evt["type"] = "user_edit"
        elif msg.startswith("before-chat-turn-"):
            evt["type"] = "before_turn"
            evt["turn_id"] = msg.replace("before-chat-turn-", "").replace("-refresh", "")
        elif msg.startswith("after-chat-turn-"):
            evt["type"] = "after_turn"
            evt["turn_id"] = msg.replace("after-chat-turn-", "")
        elif msg == "init empty branch":
            continue
        else:
            evt["type"] = "other"
        events.append(evt)
    return events


def _git_diff_stat(repo_path: str, sha: str) -> str:
    """获取某个 commit 的 diff stat"""
    r = subprocess.run(
        ["git", "diff", "--stat", f"{sha}~1", sha],
        cwd=repo_path, capture_output=True, text=True
    )
    if r.returncode != 0:
        # 可能是首个 commit
        r = subprocess.run(
            ["git", "diff", "--stat", "4b825dc642cb6eb9a060e54bf899d69f82e1fd4b", sha],
            cwd=repo_path, capture_output=True, text=True
        )
    return r.stdout.strip() if r.returncode == 0 else ""


def _parse_log_events_from_file(log_path: str, session_id: Optional[str] = None) -> List[Dict]:
    """从 stdout.log 文件中解析全部事件（可按 session_id 过滤），自动去重"""
    events = []
    seen_chat_starts = set()  # (session_id, task_id, message_id) 去重
    try:
        with open(log_path, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                # 粗过滤：行内不含 session_id 则跳过（提速）
                if session_id and session_id not in line:
                    continue
                evt = _parse_log_event(line)
                if evt:
                    # 精过滤：事件中的 session_id 必须前缀匹配
                    if session_id:
                        evt_sid = evt.get("session_id", "")
                        if not evt_sid or not evt_sid.startswith(session_id):
                            continue
                    # chat_start 去重
                    if evt["type"] == "chat_start":
                        key = (evt.get("session_id"), evt.get("task_id"), evt.get("message_id"))
                        if key in seen_chat_starts:
                            continue
                        seen_chat_starts.add(key)
                    events.append({**evt, "source": "stdout"})
    except OSError:
        pass
    return events


def cmd_events(args):
    """session 事件时间线：融合 stdout.log 事件 + snapshot git 变更"""
    trae_dir = _resolve_trae_dir(args)
    session_id = args.extra[0] if args.extra else None

    # 1. 从 stdout.log 提取事件
    log_path = _find_latest_stdout_log(trae_dir)
    log_events = []
    if log_path:
        log_events = _parse_log_events_from_file(log_path, session_id)

    # 2. 如果指定了 session_id，尝试从 snapshot git 提取事件
    snap_events = []
    snap_repo = None
    if session_id:
        snap_repo = _find_snapshot_repo(session_id)
        if snap_repo:
            snap_events = _git_log_events(snap_repo)

    # 3. 无 session_id 时列出所有可用 session 的摘要
    if not session_id:
        # 从 stdout 事件中提取 session 列表
        session_map: Dict[str, Dict] = {}
        for evt in log_events:
            sid = evt.get("session_id", "")
            if not sid:
                continue
            if sid not in session_map:
                session_map[sid] = {"session_id": sid, "first_ts": evt.get("ts"), "events": 0, "types": set()}
            session_map[sid]["events"] += 1
            session_map[sid]["types"].add(evt.get("type", ""))
            session_map[sid]["last_ts"] = evt.get("ts")

        sessions = sorted(session_map.values(), key=lambda s: s.get("first_ts") or "", reverse=True)

        if args.json_mode:
            for s in sessions:
                s["types"] = list(s["types"])
            print(json.dumps({"sessions": sessions, "total": len(sessions),
                              "log_file": log_path}, ensure_ascii=False, indent=2))
        else:
            if not sessions:
                _err("stdout.log 中未发现 session 事件（尝试指定 --trae-dir 或检查日志路径）")
                return
            print(f"日志: {os.path.basename(log_path or '')}")
            print(f"发现 {len(sessions)} 个 session:")
            print()
            for s in sessions:
                ts_short = (s.get("first_ts") or "")[:19]
                types_str = ", ".join(sorted(s["types"] - {""}))
                print(f"  {_cyan(s['session_id'][:12])}  {ts_short}  {s['events']} events  [{types_str}]")
            print()
            print(f"💡 用法: trae-cli events <session-id> 查看详细时间线")
        return

    # 4. 融合事件并按时间排序
    all_events = log_events + snap_events
    def _sort_key(e):
        ts = e.get("ts") or ""
        return ts
    all_events.sort(key=_sort_key)

    if args.json_mode:
        print(json.dumps({
            "session_id": session_id,
            "snapshot_repo": snap_repo,
            "log_file": log_path,
            "event_count": len(all_events),
            "events": all_events,
        }, ensure_ascii=False, indent=2))
        return

    # 5. 人类友好渲染
    if not all_events:
        _err(f"未找到 session {session_id} 的事件")
        return

    print(f"Session: {session_id}")
    print(f"事件数: {len(all_events)}  (stdout: {len(log_events)}, snapshot: {len(snap_events)})")
    if snap_repo:
        print(f"Snapshot: {snap_repo}")
    print()

    source_icon = {"stdout": "📋", "snapshot": "📸"}
    type_icon = {
        "chat_start": "💬", "plan_done": "📋", "toolcall": "🔧",
        "snapshot": "📸", "user_edit": "✏️", "before_turn": "⏮",
        "after_turn": "⏭", "other": "•",
    }

    for evt in all_events:
        src = source_icon.get(evt.get("source", ""), "•")
        typ = type_icon.get(evt.get("type", ""), "•")
        ts_short = (evt.get("ts") or "")[:19]

        if evt.get("source") == "snapshot":
            sha = evt.get("sha", "")
            msg = evt.get("message", "")
            detail = f"{sha} {msg}"
            # 对 toolcall 类型附加 diff stat
            if evt.get("type") == "toolcall" and snap_repo:
                stat = _git_diff_stat(snap_repo, evt["sha"])
                if stat:
                    stat_lines = stat.splitlines()
                    # 只取 summary 行
                    detail += f"  ({stat_lines[-1].strip()})" if stat_lines else ""
            print(f"  {src}{typ} {_dim(ts_short)}  {detail}")
        elif evt.get("type") == "toolcall":
            print(f"  {src}{typ} {_dim(ts_short)}  {_bold(evt.get('name', ''))} ({evt.get('status', '')})")
        elif evt.get("type") == "chat_start":
            print(f"  {src}{typ} {_dim(ts_short)}  chat 开始  task={evt.get('task_id', '')[:8]}")
        elif evt.get("type") == "plan_done":
            print(f"  {src}{typ} {_dim(ts_short)}  plan 完成 ({evt.get('cost_ms', 0)}ms)")
        else:
            etype = evt.get("type", "unknown")
            extra = ""
            if evt.get("workspace"):
                extra = f"  workspace={evt['workspace']}"
            print(f"  {src}{typ} {_dim(ts_short)}  {etype}{extra}")

    print()


