import os
import re
import shutil
import signal
import sqlite3
import subprocess
import sys
import tempfile
import textwrap
import time
import urllib.request
import urllib.error
from pathlib import Path
from typing import List, Dict, Optional

# ─── 常量 ──────────────────────────────────────────────────
# 极简 .env 加载
def _load_dotenv():
    for d in [os.path.dirname(os.path.abspath(__file__)), os.path.expanduser("~/ai/trae_space/trae-history")]:
        p = os.path.join(d, ".env")
        if os.path.isfile(p):
            with open(p, encoding="utf-8") as f:
                for line in f:
                    line = line.strip()
                    if not line or line.startswith("#") or "=" not in line:
                        continue
                    k, _, v = line.partition("=")
                    k, v = k.strip(), v.strip().strip("'\"")
                    if k and k not in os.environ:
                        os.environ[k] = v
            break
_load_dotenv()

SCRIPT_DIR = Path(__file__).resolve().parent
BIN = SCRIPT_DIR / "target" / "debug" / "autocli"
STATE_FILE = Path(os.environ.get("TMPDIR", "/tmp")) / "autocli-cdp-endpoint"
TRAE_APP = Path("/Applications/Trae CN.app")
TRAE_DIR_DEFAULT = os.path.expanduser("~/Library/Application Support/Trae CN")

VERSION = "1.2.0"

# ─── 颜色 ──────────────────────────────────────────────────
_NO_COLOR = bool(os.environ.get("NO_COLOR")) or not sys.stderr.isatty()

def _set_no_color():
    """--json 模式下动态禁用颜色"""
    global _NO_COLOR
    _NO_COLOR = True

def _c(code: str, text: str) -> str:
    return text if _NO_COLOR else f"\033[{code}m{text}\033[0m"

def _bold(t: str) -> str: return _c("1", t)
def _dim(t: str) -> str: return _c("2", t)
def _yellow(t: str) -> str: return _c("1;33", t)
def _cyan(t: str) -> str: return _c("1;36", t)
def _red(t: str) -> str: return _c("1;31", t)
def _green(t: str) -> str: return _c("1;32", t)

# 全局 json_mode 标志，由 main() 设置
_JSON_MODE = False

def _err(msg: str, code: str = ""):
    if _JSON_MODE:
        d = {"error": msg}
        if code:
            d["code"] = code
        print(json.dumps(d, ensure_ascii=False), file=sys.stderr)
    else:
        print(f"{_red('❌')} {msg}", file=sys.stderr)

def _ok(msg: str):
    if _JSON_MODE:
        print(json.dumps({"ok": True, "message": msg}, ensure_ascii=False))
    else:
        print(f"{_green('✅')} {msg}")

# ─── CDP 连接 ──────────────────────────────────────────────
def cdp_host() -> str:
    return os.environ.get("AUTOCLI_CDP_HOST", "localhost")

def cdp_port() -> str:
    return os.environ.get("AUTOCLI_CDP_PORT", "9222")

def cdp_base() -> str:
    return f"http://{cdp_host()}:{cdp_port()}"

def list_pages() -> List[Dict]:
    """获取所有 CDP page，返回 [{index, id, title, url, type}]"""
    url = f"{cdp_base()}/json/list"
    try:
        with urllib.request.urlopen(url, timeout=5) as resp:
            data = json.loads(resp.read())
    except (urllib.error.URLError, OSError):
        _err(f"无法连接 CDP ({cdp_base()})", "E1001")
        sys.exit(1)
    pages = []
    for i, item in enumerate(data):
        if item.get("type") == "page":
            pages.append({
                "index": len(pages),
                "id": item["id"],
                "title": item.get("title", ""),
                "url": item.get("url", ""),
                "type": item.get("type", ""),
            })
    return pages

def resolve_page_id(val: str, pages: Optional[List[Dict]] = None) -> str:
    """编号 → page id；若已是 UUID 则直接返回"""
    if not val.isdigit():
        return val
    if pages is None:
        pages = list_pages()
    idx = int(val) - 1  # 用户视角从 1 开始
    if idx < 0 or idx >= len(pages):
        _err(f"无效 page 编号: {val}", "E1003")
        sys.exit(1)
    return pages[idx]["id"]

def auto_detect_endpoint(page_idx: Optional[str] = None) -> str:
    """自动检测 CDP endpoint，优先级：环境变量 > --page > 持久化 > 默认第一个"""
    env = os.environ.get("AUTOCLI_CDP_ENDPOINT")
    if env:
        return env

    if page_idx:
        pid = resolve_page_id(page_idx)
        ep = f"ws://{cdp_host()}:{cdp_port()}/devtools/page/{pid}"
        os.environ["AUTOCLI_CDP_ENDPOINT"] = ep
        return ep

    if STATE_FILE.exists():
        saved = STATE_FILE.read_text().strip()
        if saved:
            os.environ["AUTOCLI_CDP_ENDPOINT"] = saved
            return saved

    pages = list_pages()
    if not pages:
        _err("未发现任何 Trae page", "E1002")
        sys.exit(1)

    if len(pages) == 1:
        pid = pages[0]["id"]
    else:
        print(f"{_cyan('🔍')} 发现 {len(pages)} 个 Trae 窗口:", file=sys.stderr)
        for p in pages:
            print(f"  [{p['index']+1}] {p['title']}  ({p['id'][:8]}...)", file=sys.stderr)
        pid = pages[0]["id"]
        print(f"  → 自动选择 [1] {pages[0]['title']}", file=sys.stderr)
        print(f"  💡 用 'trae-cli pages' 查看全部，'trae-cli use <编号>' 切换", file=sys.stderr)

    ep = f"ws://{cdp_host()}:{cdp_port()}/devtools/page/{pid}"
    STATE_FILE.write_text(ep)
    os.environ["AUTOCLI_CDP_ENDPOINT"] = ep
    return ep

# ─── autocli 执行器 ────────────────────────────────────────
def run_autocli(*args: str, capture: bool = False) -> subprocess.CompletedProcess:
    cmd = [str(BIN), "trae-cn", *args]
    if capture:
        return subprocess.run(cmd, capture_output=True, text=True)
    return subprocess.run(cmd)

# ─── 输出格式化 ────────────────────────────────────────────
def format_pages(pages: List[Dict], fmt: str, active_id: str):
    if fmt == "json":
        out = []
        for p in pages:
            out.append({**p, "index": p["index"] + 1, "active": p["id"] == active_id})
        print(json.dumps(out, ensure_ascii=False, indent=2))
    elif fmt == "csv":
        print("Index,Id,Title,Url,Type,Active")
        for p in pages:
            a = "true" if p["id"] == active_id else "false"
            t = p["title"].replace('"', '""')
            u = p["url"].replace('"', '""')
            print(f'{p["index"]+1},"{p["id"]}","{t}","{u}","{p["type"]}",{a}')
    elif fmt in ("yaml", "yml"):
        for p in pages:
            a = "true" if p["id"] == active_id else "false"
            print(f'- index: {p["index"]+1}')
            print(f'  id: "{p["id"]}"')
            print(f'  title: "{p["title"]}"')
            print(f'  url: "{p["url"]}"')
            print(f'  type: "{p["type"]}"')
            print(f'  active: {a}')
    elif fmt in ("md", "markdown"):
        print("| Index | Title | Id | Url | Type | Active |")
        print("|-------|-------|----|-----|------|--------|")
        for p in pages:
            mark = "✦" if p["id"] == active_id else ""
            print(f'| {p["index"]+1} | {p["title"]} | {p["id"]} | {p["url"]} | {p["type"]} | {mark} |')
    else:  # table
        print(f"Trae CDP Pages ({cdp_base()}):")
        print()
        for p in pages:
            mark = " ✦" if p["id"] == active_id else "  "
            print(f'{mark}[{p["index"]+1}] {p["title"]:<40s} {p["id"]}')

# ─── 子命令实现 ────────────────────────────────────────────
def cmd_pages(args):
    pages = list_pages()
    active_id = ""
    if STATE_FILE.exists():
        saved = STATE_FILE.read_text().strip()
        active_id = saved.rsplit("/", 1)[-1] if saved else ""
    format_pages(pages, args.format, active_id)

def cmd_use(args):
    idx = args.index
    pages = list_pages()
    pid = resolve_page_id(idx, pages)
    title = next((p["title"] for p in pages if p["id"] == pid), pid[:8])
    ep = f"ws://{cdp_host()}:{cdp_port()}/devtools/page/{pid}"
    STATE_FILE.write_text(ep)
    os.environ["AUTOCLI_CDP_ENDPOINT"] = ep
    if args.json_mode:
        print(json.dumps({"ok": True, "index": idx, "title": title, "endpoint": ep}, ensure_ascii=False))
    else:
        _ok(f"已切换到 [{idx}] {title}")
        print(f"   {ep}")
        print()
        run_autocli("status")

def cmd_reset(args):
    STATE_FILE.unlink(missing_ok=True)
    _ok("已清除 page 选择")

def cmd_build(args):
    r = subprocess.run(["cargo", "build"], cwd=SCRIPT_DIR, capture_output=args.json_mode)
    if args.json_mode:
        print(json.dumps({"ok": r.returncode == 0, "exit_code": r.returncode}, ensure_ascii=False))

def cmd_test(args):
    auto_detect_endpoint(args.page)
    if args.json_mode:
        r_status = run_autocli("status", "--format", "json", capture=True)
        r_read = run_autocli("read", "--format", "json", capture=True)
        result = {
            "status": {"exit_code": r_status.returncode},
            "read": {"exit_code": r_read.returncode},
        }
        try:
            result["status"]["data"] = json.loads(r_status.stdout)
        except (json.JSONDecodeError, TypeError):
            result["status"]["raw"] = (r_status.stdout or "")[:2000]
        try:
            result["read"]["data"] = json.loads(r_read.stdout)
        except (json.JSONDecodeError, TypeError):
            result["read"]["raw"] = (r_read.stdout or "")[:2000]
        print(json.dumps(result, ensure_ascii=False, indent=2))
    else:
        print("=== status ===")
        run_autocli("status")
        print()
        print("=== read (前 20 行) ===")
        r = run_autocli("read", capture=True)
        lines = (r.stdout or "").splitlines()[:20]
        print("\n".join(lines))

def cmd_smoke(args):
    auto_detect_endpoint(args.page)
    ep = os.environ.get("AUTOCLI_CDP_ENDPOINT", "?")

    cases = [
        ("status",       ["status"]),
        ("read",         ["read"]),
        ("tasks",        ["tasks"]),
        ("context",      ["context"]),
        ("config",       ["config"]),
        ("history",      ["history"]),
        ("models",       ["models"]),
        ("rules-skills", ["rules-skills"]),
        ("projects",     ["projects"]),
        ("commands",     ["commands"]),
        ("task-detail",  ["task-detail", "1"]),
        ("export",       ["export"]),
        ("dump",         ["dump"]),
    ]

    passed = failed = 0
    json_results = [] if args.json_mode else None

    if not args.json_mode:
        print(f"🧪 Trae CN 冒烟测试")
        print(f"   endpoint: {ep}")
        print()

    for i, (name, cmd_args) in enumerate(cases, 1):
        if not args.json_mode:
            sys.stdout.write(f"  [{i}] {name} ... ")
            sys.stdout.flush()
        r = run_autocli(*cmd_args, capture=True)
        output = (r.stdout or "")[:5000]
        first_line = output.split("\n", 1)[0] if output else ""
        ok_exit = r.returncode in (0, 101)
        has_error = bool(re.search(r'^(error|.*status.*error|.*role.*error|.*field.*error)', first_line, re.IGNORECASE))
        ok = ok_exit and bool(output) and not has_error

        if args.json_mode:
            entry = {"name": name, "ok": ok, "exit_code": r.returncode}
            if not ok:
                entry["output_head"] = output[:500]
            json_results.append(entry)
        elif ok:
            print(_green("✅"))
        else:
            code_info = f"exit {r.returncode}" if not ok_exit else "输出含错误"
            print(_red(f"❌ ({code_info})"))
            for line in output.splitlines()[:3]:
                print(f"      {line}")

        if ok:
            passed += 1
        else:
            failed += 1

    if args.json_mode:
        print(json.dumps({
            "endpoint": ep,
            "total": len(cases), "passed": passed, "failed": failed,
            "results": json_results,
        }, ensure_ascii=False, indent=2))
    else:
        print()
        print("━" * 25)
        print(f"  结果: {passed}/{len(cases)} 通过, {failed} 失败")
        if failed:
            print(f"  ⚠️  有失败项，请检查")
        else:
            _ok("全部通过")

    if failed:
        sys.exit(1)

def cmd_task_resolve(args):
    auto_detect_endpoint(args.page)
    session_arg = args.session

    if session_arg:
        blocked = [(session_arg, "(指定任务)")]
    else:
        r = run_autocli("tasks", "--format", "json", capture=True)
        if r.returncode != 0:
            _err("无法获取任务列表", "E2002")
            if r.stderr:
                print(r.stderr, file=sys.stderr)
            ep = os.environ.get("AUTOCLI_CDP_ENDPOINT", "未设置")
            print(f"   💡 请检查 --page 参数是否有效，当前 endpoint: {ep}", file=sys.stderr)
            sys.exit(1)

        try:
            tasks_data = json.loads(r.stdout)
        except json.JSONDecodeError:
            _err("任务列表 JSON 解析失败", "E3002")
            sys.exit(1)

        blocked = []
        for t in tasks_data:
            status = t.get("Status", "")
            if any(kw in status.lower() for kw in ("等待", "waiting", "⏳")):
                blocked.append((t.get("SessionId", ""), t.get("Title", "")))

        if not blocked:
            _ok("当前没有阻塞的任务")
            return

    # 选择目标任务
    if len(blocked) == 1:
        target_sid, target_title = blocked[0]
    else:
        print()
        print(f"  ╭{'─'*50}╮")
        print(f"  │  📋 发现 {len(blocked)} 个阻塞任务，请选择要处理的任务{' '*(50-26-len(str(len(blocked))))}│")
        print(f"  ╰{'─'*50}╯")
        print()
        for i, (sid, title) in enumerate(blocked, 1):
            print(f"  {_yellow(f'[{i}]')} {title}")
            print(f"      {_dim(sid)}")
        print()
        try:
            choice = int(input(f"  请选择 [1-{len(blocked)}]: "))
        except (ValueError, EOFError):
            _err("无效选择")
            sys.exit(1)
        if choice < 1 or choice > len(blocked):
            _err("无效选择")
            sys.exit(1)
        target_sid, target_title = blocked[choice - 1]

    # 获取问询信息
    r = run_autocli("task-ask", "--session", target_sid, "--format", "json", capture=True)
    if r.returncode != 0:
        _err(f"无法获取任务问询信息 (session: {target_sid})", "E2002")
        sys.exit(1)

    try:
        ask_data = json.loads(r.stdout)
    except json.JSONDecodeError:
        _err("问询 JSON 解析失败", "E3002")
        sys.exit(1)

    # 提取问题
    question = ""
    for item in ask_data:
        if item.get("Type") == "Question":
            question = item.get("Label", "")
            break

    if not question:
        print(f"ℹ️  任务 [{target_title}] 当前没有待回答的问询")
        return

    # 提取选项
    options = [item for item in ask_data if item.get("Type") != "Question"]

    # 渲染 UI
    box_w = 64
    border = "─" * box_w
    title_display = target_title[:50] + "..." if len(target_title) > 50 else target_title

    print()
    print(f"  {_cyan('╭' + border + '╮')}")
    pad = box_w - 3 - len(title_display)
    print(f"  {_cyan('│')} {_bold('❓ ' + title_display)}{' '*max(pad,0)} {_cyan('│')}")
    print(f"  {_cyan('├' + border + '┤')}")

    # 问题文本折行
    for line in textwrap.wrap(question, width=60):
        pad = box_w - 2 - len(line)
        print(f"  {_cyan('│')}  {line}{' '*max(pad,0)} {_cyan('│')}")

    print(f"  {_cyan('├' + border + '┤')}")

    for opt in options:
        oidx = opt.get("Index", "?")
        olabel = opt.get("Label", "")
        odesc = opt.get("Description", "")
        pad = box_w - 6 - len(str(oidx)) - len(olabel)
        print(f"  {_cyan('│')}  {_yellow(f'[{oidx}]')} {_bold(olabel)}{' '*max(pad,0)} {_cyan('│')}")
        if odesc:
            pad = box_w - 6 - len(odesc)
            print(f"  {_cyan('│')}      {_dim(odesc)}{' '*max(pad,0)} {_cyan('│')}")

    print(f"  {_cyan('╰' + border + '╯')}")
    print()

    try:
        opt_choice = input(f"  请选择选项 [1-{len(options)}] (q 取消): ").strip()
    except EOFError:
        print("  已取消")
        return

    if opt_choice.lower() == "q":
        print("  已取消")
        return

    try:
        opt_idx = int(opt_choice)
    except ValueError:
        _err("无效选择")
        sys.exit(1)

    if opt_idx < 1 or opt_idx > len(options):
        _err("无效选择")
        sys.exit(1)

    # 检查是否需要文本输入
    selected_opt = options[opt_idx - 1]
    input_text = ""
    if "input" in selected_opt.get("Type", "").lower():
        input_text = input("  请输入内容: ")

    print()
    print("  ⏳ 正在提交选择...")

    submit_args = ["task-ask", "--session", target_sid, "--select", str(opt_idx), "--format", "json"]
    if input_text:
        submit_args.extend(["--text", input_text])
    r = run_autocli(*submit_args, capture=True)

    try:
        result_data = json.loads(r.stdout or "[]")
        submitted = ""
        for item in result_data:
            if item.get("Type") == "Submitted":
                submitted = item.get("Label", "")
                break
        if submitted:
            _ok(f"已提交: {submitted}")
        else:
            print("  ⚠️  提交结果:")
            for line in (r.stdout or "").splitlines()[:5]:
                print(f"      {line}")
    except json.JSONDecodeError:
        print("  ⚠️  提交结果:")
        for line in (r.stdout or "").splitlines()[:5]:
            print(f"      {line}")
    print()

def cmd_init_env(args):
    port = cdp_port()
    env_key = "ELECTRON_EXTRA_LAUNCH_ARGS"
    env_val = f"--remote-debugging-port={port}"
    plist_label = "com.user.electron-cdp-env"
    plist_path = Path.home() / "Library" / "LaunchAgents" / f"{plist_label}.plist"

    # 检查当前状态
    r = subprocess.run(["launchctl", "getenv", env_key], capture_output=True, text=True)
    current = r.stdout.strip()
    if current == env_val:
        if args.json_mode:
            print(json.dumps({"ok": True, "action": "noop", "message": f"{env_key}={env_val} 已设置"}, ensure_ascii=False))
        else:
            _ok(f"环境变量已设置: {env_key}={env_val}")
            print("   无需重复操作")
        return

    subprocess.run(["launchctl", "setenv", env_key, env_val], check=True)

    plist_content = f"""\
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>{plist_label}</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/launchctl</string>
        <string>setenv</string>
        <string>{env_key}</string>
        <string>{env_val}</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>"""
    plist_path.write_text(plist_content)
    subprocess.run(["launchctl", "load", str(plist_path)], stderr=subprocess.DEVNULL)

    if args.json_mode:
        print(json.dumps({"ok": True, "action": "set", "env_key": env_key, "env_val": env_val,
                          "plist": str(plist_path)}, ensure_ascii=False))
    else:
        _ok(f"已设置当前会话环境变量: {env_key}={env_val}")
        _ok(f"已写入 LaunchAgent: {plist_path}")
        print("   重启后自动生效")
        print()
        print("⚠️  需要完全退出 Trae CN 后重新打开才能生效")
        print(f'   退出: osascript -e \'quit app "Trae CN"\'')
        print(f'   启动: open "{TRAE_APP}"')

def cmd_init_wrapper(args):
    electron_dir = TRAE_APP / "Contents" / "MacOS"
    electron_bin = electron_dir / "Electron"
    electron_orig = electron_dir / "Electron.orig"
    port = cdp_port()
    is_json = args.json_mode

    if not TRAE_APP.is_dir():
        _err(f"未找到 Trae CN: {TRAE_APP}", "E2001")
        sys.exit(1)

    if electron_orig.exists():
        r = subprocess.run(["file", "-b", str(electron_orig)], capture_output=True, text=True)
        if "Mach-O" in r.stdout:
            if not is_json:
                print(f"ℹ️  Electron.orig 已存在 (Mach-O binary)")
        else:
            _err(f"Electron.orig 存在但不是 Mach-O binary: {r.stdout.strip()}", "E2002")
            sys.exit(1)
    else:
        r = subprocess.run(["file", "-b", str(electron_bin)], capture_output=True, text=True)
        if "Mach-O" in r.stdout:
            subprocess.run(["sudo", "cp", str(electron_bin), str(electron_orig)], check=True)
            if not is_json:
                _ok("已备份原始二进制: Electron → Electron.orig")
        else:
            _err("Electron 已是脚本，但找不到 Electron.orig", "E2002")
            if not is_json:
                r2 = subprocess.run(["head", "-3", str(electron_bin)], capture_output=True, text=True)
                print(f"    当前内容:\n{r2.stdout}", file=sys.stderr)
            sys.exit(1)

    wrapper = f"""\
#!/bin/bash
DIR="$(cd "$(dirname "$0")" && pwd)"
if [ "$ELECTRON_RUN_AS_NODE" = "1" ]; then
    exec "$DIR/Electron.orig" "$@"
else
    exec "$DIR/Electron.orig" --remote-debugging-port={port} "$@"
fi"""

    subprocess.run(["sudo", "tee", str(electron_bin)], input=wrapper.encode(), stdout=subprocess.DEVNULL, check=True)
    subprocess.run(["sudo", "chmod", "+x", str(electron_bin)], check=True)

    if is_json:
        print(json.dumps({"ok": True, "action": "wrapper_installed",
                          "electron_bin": str(electron_bin), "port": port}, ensure_ascii=False))
    else:
        _ok(f"已写入 wrapper 脚本: {electron_bin}")
        print()
        print(wrapper)
        print()
        print("⚠️  需要完全退出 Trae CN 后重新打开才能生效")
        print(f'   退出: osascript -e \'quit app "Trae CN"\'')
        print(f'   启动: open "{TRAE_APP}"')
        print()
        print("💡 注意: Trae CN 更新后可能覆盖此修改，需重新执行 init-wrapper")

def cmd_passthrough(args):
    """透传 autocli trae-cn 子命令"""
    auto_detect_endpoint(args.page)
    os.environ["AUTOCLI_FOCUS_APP"] = "Trae CN"
    cmd_args = [args.subcmd] + args.extra
    if args.json_mode:
        cmd_args.extend(["--format", "json"])
    elif args.format != "table":
        cmd_args.extend(["--format", args.format])
    run_autocli(*cmd_args)

# ─── 本地数据源：vscdb 查询 + 日志监听 ─────────────────────
def _resolve_mode() -> str:
    """解析运行模式：cdp / local / auto（自动检测）
    TRAE_MODE 环境变量优先；auto 模式下检测 CDP endpoint 是否可达。
    """
    mode = os.environ.get("TRAE_MODE", "auto").lower()
    if mode in ("cdp", "local"):
        return mode
    # auto: 有可用 CDP endpoint → cdp，否则 local
    if os.environ.get("AUTOCLI_CDP_ENDPOINT"):
        return "cdp"
    if STATE_FILE.exists():
        try:
            saved = STATE_FILE.read_text().strip()
            if saved:
                return "cdp"
        except Exception:
            pass
    # 尝试探测 CDP 端口
    try:
        port = cdp_port()
        url = f"http://{cdp_host()}:{port}/json/list"
        req = urllib.request.Request(url, method="GET")
        resp = urllib.request.urlopen(req, timeout=1)
        if resp.status == 200:
            return "cdp"
    except Exception:
        pass
    return "local"


def _require_cdp_mode(cmd_name: str):
    """在 local 模式下调用 CDP-only 命令时报错退出"""
    _err(f"命令 '{cmd_name}' 需要 CDP 模式（设置 TRAE_MODE=cdp 或确保 CDP 端口可达）", "E7001")
    sys.exit(1)


def _resolve_trae_dir(args) -> str:
    """从 args / 环境变量 / 默认值中解析 Trae 数据目录"""
    d = getattr(args, "trae_dir", None) or os.environ.get("TRAE_DIR") or TRAE_DIR_DEFAULT
    if not os.path.isdir(d):
        _err(f"Trae 数据目录不存在: {d}", "E5001")
        sys.exit(1)
    return d


def _find_workspace_db(trae_dir: str, project_path: str) -> Optional[str]:
    """根据项目路径在 workspaceStorage 中查找 state.vscdb"""
    ws_root = os.path.join(trae_dir, "User", "workspaceStorage")
    if not os.path.isdir(ws_root):
        return None
    target_uri = f"file://{os.path.realpath(project_path)}"
    for folder in os.listdir(ws_root):
        ws_json = os.path.join(ws_root, folder, "workspace.json")
        if os.path.isfile(ws_json):
            try:
                with open(ws_json, "r", encoding="utf-8") as f:
                    data = json.load(f)
                if data.get("folder") == target_uri:
                    db = os.path.join(ws_root, folder, "state.vscdb")
                    if os.path.isfile(db):
                        return db
            except Exception:
                continue
    return None


def _query_vscdb(db_path: str, key: Optional[str] = None,
                 like_pattern: Optional[str] = None) -> Optional[str]:
    """查询 state.vscdb 的 ItemTable（临时拷贝避免锁冲突）"""
    tmp_db = os.path.join(tempfile.gettempdir(), f"trae_cli_vscdb_{os.getpid()}.db")
    try:
        shutil.copy2(db_path, tmp_db)
        conn = sqlite3.connect(tmp_db)
        cur = conn.cursor()
        if key:
            cur.execute("SELECT value FROM ItemTable WHERE key = ?", (key,))
        elif like_pattern:
            cur.execute("SELECT value FROM ItemTable WHERE key LIKE ?", (like_pattern,))
        else:
            conn.close()
            return None
        row = cur.fetchone()
        conn.close()
        return row[0] if row else None
    except Exception:
        return None
    finally:
        if os.path.exists(tmp_db):
            os.remove(tmp_db)


def _query_vscdb_all(db_path: str, like_pattern: str) -> List[str]:
    """查询 state.vscdb 的 ItemTable，返回所有匹配行的 value"""
    tmp_db = os.path.join(tempfile.gettempdir(), f"trae_cli_vscdb_{os.getpid()}.db")
    try:
        shutil.copy2(db_path, tmp_db)
        conn = sqlite3.connect(tmp_db)
        cur = conn.cursor()
        cur.execute("SELECT value FROM ItemTable WHERE key LIKE ?", (like_pattern,))
        rows = cur.fetchall()
        conn.close()
        return [row[0] for row in rows]
    except Exception:
        return []
    finally:
        if os.path.exists(tmp_db):
            os.remove(tmp_db)


def _derive_session_status(messages: List[Dict]) -> str:
    """从消息列表推导会话状态"""
    if not messages:
        return "待处理"
    last_assistant = None
    for msg in reversed(messages):
        if msg.get("role") == "assistant":
            last_assistant = msg
            break
    if not last_assistant:
        return "待处理"
    status = (last_assistant.get("status") or "").lower()
    if status in ("done", "finished", "completed", "success"):
        return "已完成"
    if status in ("streaming", "running", "pending", "thinking"):
        return "进行中"
    if status in ("waiting", "need_confirm", "need_manual_confirm"):
        return "等待操作"
    if status in ("error", "failed", "cancelled", "stopped"):
        return "已停止"
    content = last_assistant.get("content", "")
    if not content:
        task_content = last_assistant.get("agentTaskContent", {})
        if isinstance(task_content, dict):
            content = task_content.get("proposal", "")
    return "已完成" if content else "进行中"


def _extract_session_title(messages: List[Dict], session_id: str) -> str:
    """提取会话标题：取第一条用户消息首行，截断至 60 字符"""
    for msg in messages:
        if msg.get("role") == "user" and msg.get("content"):
            first_line = msg["content"].strip().split("\n", 1)[0]
            return first_line[:57] + "..." if len(first_line) > 60 else first_line
    return f"Session {session_id[:8]}"


def _extract_trae_sessions(trae_dir: str, project_path: str) -> List[Dict]:
    """提取会话列表：从 vscdb 读取"""
    db_path = _find_workspace_db(trae_dir, project_path)
    if not db_path:
        return []

    # 路线 A: ng-chat-storage
    raw = _query_vscdb(db_path, like_pattern="memento/icube-ai-ng-chat-storage-%")
    if raw:
        try:
            data = json.loads(raw)
        except json.JSONDecodeError:
            data = {}
        sessions = []
        for s in data.get("list", []):
            sid = s.get("sessionId", "")
            if not sid:
                continue
            messages = s.get("messages", [])
            sessions.append({
                "SessionId": sid,
                "Title": _extract_session_title(messages, sid),
                "Status": _derive_session_status(messages),
                "MessageCount": len(messages),
                "CreatedAt": s.get("createdAt"),
                "UpdatedAt": s.get("updatedAt"),
            })
        if sessions:
            return sessions

    # 路线 B: icube_session_agent_map + input-history
    agent_map_raw = _query_vscdb(db_path, key="icube_session_agent_map")
    if not agent_map_raw:
        return []
    try:
        agent_map = json.loads(agent_map_raw)
    except json.JSONDecodeError:
        return []
    if not isinstance(agent_map, dict):
        return []

    input_raw = _query_vscdb(db_path, key="icube-ai-agent-storage-input-history")
    inputs: List[str] = []
    if input_raw:
        try:
            input_data = json.loads(input_raw)
            if isinstance(input_data, list):
                inputs = [
                    item.get("inputText", "").strip().split("\n", 1)[0][:60]
                    for item in input_data
                    if isinstance(item, dict) and item.get("inputText")
                ]
        except json.JSONDecodeError:
            pass

    sessions = []
    for idx, (sid, agent_type) in enumerate(agent_map.items()):
        sessions.append({
            "SessionId": sid,
            "Title": inputs[idx] if idx < len(inputs) else f"Session {sid[:8]}",
            "Status": "已完成",
            "MessageCount": 0,
            "CreatedAt": None,
            "UpdatedAt": None,
        })
    return sessions


def _search_session_in_db(db_path: str, session_id: str) -> Optional[Dict]:
    """在单个 vscdb 中搜索指定 session，支持前缀匹配"""
    values = _query_vscdb_all(db_path, "memento/icube-ai-ng-chat-storage-%")
    for raw in values:
        try:
            data = json.loads(raw)
        except json.JSONDecodeError:
            continue
        for s in data.get("list", []):
            sid = s.get("sessionId", "")
            if sid == session_id or sid.startswith(session_id):
                return {
                    "sessionId": sid,
                    "messages": s.get("messages", []),
                    "createdAt": s.get("createdAt"),
                    "updatedAt": s.get("updatedAt"),
                    "db_path": db_path,
                }
    return None


def _find_session_messages(trae_dir: str, session_id: str,
                           project_path: Optional[str] = None) -> Optional[Dict]:
    """查找指定 session 的完整消息：从 vscdb 读取"""
    if project_path:
        db_path = _find_workspace_db(trae_dir, project_path)
        if db_path:
            result = _search_session_in_db(db_path, session_id)
            if result:
                return result
        return None
    # 无项目路径时遍历全部 workspace
    ws_root = os.path.join(trae_dir, "User", "workspaceStorage")
    if not os.path.isdir(ws_root):
        return None
    for folder in os.listdir(ws_root):
        db_path = os.path.join(ws_root, folder, "state.vscdb")
        if os.path.isfile(db_path):
            result = _search_session_in_db(db_path, session_id)
            if result:
                return result
    return None


def _format_message_for_output(msg: Dict, index: int) -> Dict:
    """将 vscdb 消息格式化为与 CDP read 对齐的输出结构"""
    role = msg.get("role", "unknown")
    content = msg.get("content", "")
    status = msg.get("status", "")
    agent_task = msg.get("agentTaskContent")

    # 角色映射
    role_map = {"user": "User", "assistant": "Assistant", "system": "System"}
    display_role = role_map.get(role, role.capitalize())

    # 类型推导
    if role == "user":
        msg_type = "message"
    elif agent_task:
        msg_type = "agent-task"
    elif role == "system":
        msg_type = "system"
    else:
        msg_type = "text"

    text = content or ""
    if agent_task and isinstance(agent_task, dict):
        # agentTaskContent 可能包含 steps/toolCalls 等结构化数据
        steps = agent_task.get("steps", [])
        if steps:
            parts = []
            for step in steps:
                step_content = step.get("content", "")
                tool_calls = step.get("toolCalls", [])
                if step_content:
                    parts.append(step_content)
                for tc in tool_calls:
                    tool_name = tc.get("toolName", "unknown")
                    tool_status = tc.get("status", "")
                    parts.append(f"[tool:{tool_name} status:{tool_status}]")
            text = "\n".join(parts) if parts else text

    # 截断超长内容
    if len(text) > 10000:
        text = text[:10000] + "... (truncated)"

    return {
        "Index": index,
        "Role": display_role,
        "Type": msg_type,
        "Status": status,
        "Text": text or "(empty)",
    }


def _read_local(args):
    """读取指定 session 的完整消息内容（从 vscdb 读取）"""
    trae_dir = _resolve_trae_dir(args)

    if not args.extra:
        _err("用法: trae-cli read <session-id> [project-path]", "E6001")
        sys.exit(1)

    session_id = args.extra[0]
    project_path = args.extra[1] if len(args.extra) > 1 else None
    if project_path:
        project_path = os.path.realpath(os.path.expanduser(project_path))

    result = _find_session_messages(trae_dir, session_id, project_path)
    if not result:
        if args.json_mode:
            print(json.dumps({"error": f"未找到 session: {session_id}", "code": "E6002"},
                             ensure_ascii=False))
        else:
            _err(f"未找到 session: {session_id}（尝试用 history 命令获取 session 列表）", "E6002")
        sys.exit(1)

    messages = result["messages"]
    formatted = [_format_message_for_output(msg, i) for i, msg in enumerate(messages)]

    if args.json_mode:
        print(json.dumps({
            "sessionId": result["sessionId"],
            "messageCount": len(messages),
            "createdAt": result.get("createdAt"),
            "updatedAt": result.get("updatedAt"),
            "db_path": result.get("db_path"),
            "messages": formatted,
        }, ensure_ascii=False, indent=2))
    else:
        print(f"Session: {result['sessionId']}")
        print(f"消息数: {len(messages)}")
        if result.get("createdAt"):
            print(f"创建: {result['createdAt']}")
        if result.get("updatedAt"):
            print(f"更新: {result['updatedAt']}")
        print()
        for m in formatted:
            role_color = {"User": "\033[36m", "Assistant": "\033[32m",
                          "System": "\033[33m"}.get(m["Role"], "")
            reset = "\033[0m" if role_color else ""
            header = f"{role_color}[{m['Index']}] {m['Role']}{reset} ({m['Type']})"
            if m["Status"]:
                header += f" [{m['Status']}]"
            print(header)
            # 缩进文本，限制预览行数
            lines = m["Text"].split("\n")
            preview = lines[:20]
            for line in preview:
                print(f"  {line}")
            if len(lines) > 20:
                print(f"  ... ({len(lines) - 20} more lines)")
            print()


